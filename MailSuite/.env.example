# ─── Server ────────────────────────────────────────────
PORT=5050
NODE_ENV=production
SESSION_SECRET=changez-ce-secret-en-production
SELF_URL=http://VOTRE_IP_VPS:5050
FRONTEND_URL=http://VOTRE_IP_VPS:3000

# ─── Cloudflare ────────────────────────────────────────
# Can manage multiple tokens via the UI, this is the default
CF_API_TOKEN=
CF_ZONE_ID=

# ─── Microsoft 365 ─────────────────────────────────────
# Azure AD App Registration
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ─── N8N Integration ──────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=

# ─── Telegram Alerts ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
